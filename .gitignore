# Untracked bulk inputs, caches and run outputs. Intentionally tracked, reviewed
# release artifacts (for example 01_programs/app/data/) remain tracked; see
# DATA_POLICY.md. A .gitignore rule never removes an already tracked release file.
.scratch/
/data/
outputs/
*.h5ad
*.h5mu

# Secrets / local (infra.env is tracked and non-secret; .env is NOT)
.env
*.local

# OS
.DS_Store

# Pipeline runtime data (re-fetchable from a content-addressed manifest)
pipeline/datasets/

# e2e run outputs
pipeline/tests/e2e/work/
01_programs/analysis/_t8_staging/
# Stage-1 -> Stage-2 bridge: generated/large staging bundle (projections + hardlinked parquet)
01_programs/analysis/stage2_bridge/_release_staging/
