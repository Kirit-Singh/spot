# spot infrastructure — TRACKED, non-secret host/paths/ports. No credentials here.
# (Secrets go in an untracked .env; see .gitignore.)

# Lane A / shared: dev + web/API + orchestration host (Ubuntu 24.04, docker, data mount live)
SPOT_DEV_HOST=tcedirector
# GPU compute/worker target (3x RTX 3090); dataset not yet mounted there
SPOT_GPU_HOST=tcefold
# Lane B: DGX Spark cluster (2x GB10) — DeepSeek serving today; optional training modality
SPOT_SPARK_HOSTS=tcespark,tcespark2

# NAS / dataset source (NFS) — never a live-run dependency
SPOT_NAS=192.168.68.69:/volume1/datasets
SPOT_DATASET_DIR=/mnt/tcenas/datasets/raw/public/marson2025_gwcd4_perturbseq
# Local fast scratch for copied small precomputed files
SPOT_SCRATCH_DIR=.scratch

# Localhost dev ports
SPOT_API_PORT=8000
SPOT_FRONTEND_PORT=5173
